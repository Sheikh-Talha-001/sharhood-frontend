# ============================================================
# ShareHood Frontend — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
#
# Backend API base URL (without trailing slash)
# Local development: http://localhost:5000/api
# Production: https://your-api.example.com/api
VITE_API_URL=http://localhost:5000/api

# Socket.io Server URL (without trailing slash)
# Local development: http://localhost:5000
# Production: https://your-api.example.com
VITE_SOCKET_URL=http://localhost:5000

