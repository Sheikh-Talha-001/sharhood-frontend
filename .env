# ============================================================
# ShareHood Frontend — Environment Variables
# ============================================================
# Backend API base URL (without trailing slash)
# VITE_API_URL=https://sharehood-backend-production.up.railway.app/api
VITE_API_URL=http://localhost:5000/api

# Socket.IO server URL — must point to the server ROOT (not /api)
# In dev: http://localhost:5000
# In prod: https://sharehood-backend-production.up.railway.app
# VITE_SOCKET_URL=https://sharehood-backend-production.up.railway.app
VITE_SOCKET_URL=http://localhost:5000
